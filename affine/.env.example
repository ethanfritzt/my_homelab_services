# AFFiNE configuration
# Copy this file to .env and fill in your values

# AFFiNE release channel: stable, beta, or canary
AFFINE_REVISION=stable

# Port the AFFiNE container exposes on the host
PORT=3030

# Set these to enable HTTPS links and correct external URLs
AFFINE_SERVER_HTTPS=true
AFFINE_SERVER_HOST=notes.mydomain.com

# Data directories (relative to this docker-compose.yml)
DB_DATA_LOCATION=./postgres
UPLOAD_LOCATION=./storage
CONFIG_LOCATION=./config

# Database credentials
DB_USERNAME=affine
DB_PASSWORD=replace_with_strong_password
DB_DATABASE=affine
