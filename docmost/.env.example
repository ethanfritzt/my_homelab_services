# Docmost configuration
# Copy this file to .env and fill in your values

# The URL you'll access Docmost from (must match your Caddy/DNS setup)
APP_URL=https://notes.mydomain.com

# A long random secret key (32 characters minimum)
# Generate with: openssl rand -hex 32
APP_SECRET=replace_with_openssl_rand_hex_32

# PostgreSQL password (use a strong password)
POSTGRES_PASSWORD=replace_with_strong_password

# Database connection string (update the password to match POSTGRES_PASSWORD)
DATABASE_URL=postgresql://docmost:replace_with_strong_password@docmost-db:5432/docmost

# Redis connection string
REDIS_URL=redis://docmost-redis:6379
